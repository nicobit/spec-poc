# Example environment file for backend (copy to `.env` and fill values)
# Only populate secrets/keys in production via Azure Key Vault and Managed Identity

# --- Key Vault & Azure credentials (required for live Azure Key Vault + OpenAI) ---
KEY_VAULT_CORE_URI=https://<your-key-vault-name>.vault.azure.net
KEY_VAULT_URI=https://<your-key-vault-name>.vault.azure.net

# If you use DefaultAzureCredential locally (VS Code auth), set VSCODE=true
# For production with Managed Identity leave VSCODE unset or false.
VSCODE=true

# Optional: service principal for local/dev flows (DefaultAzureCredential will pick these up)
AZURE_TENANT_ID=<your-tenant-id>
AZURE_CLIENT_ID=<your-client-id>
AZURE_CLIENT_SECRET=<your-client-secret>

# --- Key Vault secret names (these are *names* of secrets stored in Key Vault) ---
# Create these secrets in Key Vault and set the secret names here
AZURE_OPENAI_KEY_SECRET_NAME=azure-openai-key
AZURE_OPENAI_ENDPOINT_SECRET_NAME=azure-openai-endpoint
AZURE_OPENAI_VERSION_SECRET_NAME=azure-openai-version

# The app uses the completion model name as the Azure OpenAI deployment name
COMPLETION_MODEL=gpt-35-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# CORS and app insights (optional)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Database / storage (optional for AI feature; include if your app uses them)
DATABASE_NAME=
SQL_CONNECTION_STRING=
SQL_CONNECTION_STRING_SECRET_NAME=

# Chat session (FEAT-ASSISTANT-003)
# Set COSMOS_CONNECTION_STRING to enable persistent Cosmos DB sessions; omit for in-memory fallback
COSMOS_CONNECTION_STRING=
COSMOS_CHAT_CONTAINER_NAME=chatsessions
CHAT_HISTORY_TOKEN_BUDGET=3000
CHAT_SUMMARIZE_THRESHOLD=6
CHAT_SESSION_TTL_DAYS=7

# Other optional overrides
ROWS_LIMIT=100

# Notes:
# - Copy this file to `backend/.env` (or set variables in your environment) before running the backend.
# - In production, do NOT store secret values in plaintext — store secrets in Key Vault and set the secret NAMES above.